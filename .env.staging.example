NODE_ENV=production
PORT=4000
WEB_ORIGIN=https://portfolio-staging.example.com
NEXT_PUBLIC_API_URL=https://portfolio-api-staging.example.com/api/v1
INTERNAL_API_URL=https://portfolio-api-staging.example.com/api/v1
DATABASE_URL=postgresql://staging-user:password@staging-host/staging-db?sslmode=require
DATABASE_POOL_MAX=5
DATABASE_POOL_TIMEOUT_SECONDS=10
REDIS_URL=rediss://default:password@staging-redis-host:6379
JWT_ACCESS_SECRET=replace-with-a-unique-32-character-staging-secret
JWT_REFRESH_SECRET=replace-with-another-unique-32-character-secret
INCOMING_WEBHOOK_SECRET=replace-with-a-third-unique-32-character-secret
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfolio-staging-media
R2_RESUME_KEY=resume/akinode-resume.pdf
SENTRY_DSN=
RUN_WORKER_IN_API=true
