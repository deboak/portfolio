{
  "name": "@portfolio/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');for(const path of ['.next','.next-dev'])fs.rmSync(path,{recursive:true,force:true})\"",
    "clean:dev": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true})\"",
    "clean:build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "predev": "npm run clean:dev",
    "dev": "next dev -p 3001",
    "prebuild": "npm run clean:build",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.66.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
