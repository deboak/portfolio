{
  "name": "portfolio-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,yellow,magenta \"npm run dev -w @portfolio/api\" \"npm run dev:worker -w @portfolio/api\" \"npm run dev -w @portfolio/web\"",
    "build": "npm run build -w @portfolio/api && npm run build -w @portfolio/web",
    "typecheck": "npm run typecheck -w @portfolio/api && npm run typecheck -w @portfolio/web",
    "test": "npm run test -w @portfolio/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "npm run lint -w @portfolio/web",
    "format:api": "prettier --write \"apps/api/{src,prisma,tests}/**/*.ts\"",
    "format:api:check": "prettier --check \"apps/api/{src,prisma,tests}/**/*.ts\"",
    "db:generate": "npm run db:generate -w @portfolio/api",
    "db:migrate": "npm run db:migrate -w @portfolio/api",
    "db:seed": "npm run db:seed -w @portfolio/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.3",
    "next": {
      "postcss": "^8.5.10",
      "sharp": "^0.35.3"
    }
  }
}
